{
  "name": "zomboid-cli",
  "version": "0.1.0",
  "module": "src/index.tsx",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun run src/index.tsx",
    "dev": "bun run --watch src/index.tsx",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "type-check": "tsc --noEmit",
    "build": "bun build ./src/index.tsx --outdir ./dist --target node --minify",
    "build:exe": "bun build ./src/index.tsx --compile --outfile zomboid-cli",
    "clean": "rm -rf dist cdktf.out",
    "lint": "bunx biome lint ./src",
    "lint:fix": "bunx biome lint --write ./src"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/ink-big-text": "^1.2.4",
    "@types/ink-testing-library": "^1.0.4",
    "@types/react": "^19.0.0",
    "@types/ssh2": "^1.15.5",
    "ink-testing-library": "^4.0.0",
    "react-devtools-core": "^7.0.1"
  },
  "peerDependencies": {
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@cdktf/provider-google": "^16.12.1",
    "@mishieck/ink-titled-box": "^0.4.2",
    "cdktf": "^0.21.0",
    "constructs": "^10.6.0",
    "figures": "^6.1.0",
    "ink": "^7.0.0",
    "ink-big-text": "^2.0.0",
    "ink-gradient": "^4.0.0",
    "react": "^19.2.5",
    "ssh2": "^1.17.0",
    "zustand": "^5.0.12"
  }
}
